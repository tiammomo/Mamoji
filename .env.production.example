# Copy to .env.production and replace every placeholder before deployment.

MAMOJI_PUBLIC_HOST=mamoji.example.com
MAMOJI_PUBLIC_API_BASE_URL=https://mamoji.example.com/api/v1
MAMOJI_TLS_EMAIL=ops@example.com
MAMOJI_COMPOSE_PROJECT_NAME=mamoji-prod
MAMOJI_RUNTIME_ENVIRONMENT=production

MAMOJI_CADDY_VERSION=2.11.4-alpine
MAMOJI_MINIO_VERSION=RELEASE.2025-09-07T16-13-09Z
MAMOJI_PROMETHEUS_VERSION=v3.12.0
MAMOJI_BACKUP_HELPER_IMAGE=alpine:3.23.4

MAMOJI_POSTGRES_DB=mamoji
MAMOJI_POSTGRES_USER=mamoji_app
MAMOJI_POSTGRES_PASSWORD=replace-with-a-long-random-password
MAMOJI_DB_POOL_MAX_SIZE=20
MAMOJI_DB_POOL_MIN_IDLE=4
MAMOJI_SCHEMA_COMPATIBILITY_ENABLED=false

MAMOJI_BOOTSTRAP_MODE=bootstrap
MAMOJI_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
MAMOJI_BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-long-random-admin-password
MAMOJI_BOOTSTRAP_ADMIN_NICKNAME=系统管理员
MAMOJI_BOOTSTRAP_COMPANY_NAME=我的公司
MAMOJI_BOOTSTRAP_COMPANY_CREDIT_CODE=
MAMOJI_BOOTSTRAP_COMPANY_INDUSTRY=未设置
MAMOJI_BOOTSTRAP_COMPANY_TAXPAYER_TYPE=未设置
MAMOJI_BOOTSTRAP_COMPANY_CURRENCY=CNY
MAMOJI_FLYWAY_ENABLED=true
MAMOJI_REGISTRATION_MODE=invite
MAMOJI_ALLOWED_ORIGINS=https://mamoji.example.com
MAMOJI_AUTH_MAX_FAILED_ATTEMPTS=5
MAMOJI_AUTH_MAX_FAILED_ATTEMPTS_PER_SOURCE=50
MAMOJI_AUTH_FAILURE_WINDOW_MINUTES=15
MAMOJI_AUTH_LOCK_MINUTES=15
MAMOJI_PASSWORD_MIN_LENGTH=12
MAMOJI_PASSWORD_REQUIRE_COMPLEXITY=true
MAMOJI_OUTBOX_ENABLED=true
MAMOJI_OUTBOX_CONSUMER_ENABLED=true
MAMOJI_OUTBOX_CONSUMER_FIXED_DELAY_MS=5000
MAMOJI_OUTBOX_CONSUMER_BATCH_SIZE=20
MAMOJI_OUTBOX_CONSUMER_MAX_ATTEMPTS=8
MAMOJI_OUTBOX_CONSUMER_STALE_LOCK_MINUTES=10
MAMOJI_NOTIFICATIONS_ENABLED=true
MAMOJI_NOTIFICATION_REMINDERS_ENABLED=true
MAMOJI_NOTIFICATION_REMINDER_FIXED_DELAY_MS=60000
MAMOJI_NOTIFICATION_TAX_LOOKAHEAD_DAYS=7
MAMOJI_NOTIFICATION_PEOPLE_LOOKAHEAD_DAYS=14
MAMOJI_NOTIFICATION_RECEIPT_LOOKAHEAD_DAYS=7
MAMOJI_NOTIFICATION_DELIVERY_ENABLED=true
MAMOJI_NOTIFICATION_DELIVERY_FIXED_DELAY_MS=10000
MAMOJI_NOTIFICATION_DELIVERY_BATCH_SIZE=20
MAMOJI_NOTIFICATION_DELIVERY_MAX_ATTEMPTS=6
MAMOJI_NOTIFICATION_DELIVERY_STALE_LOCK_MINUTES=10
MAMOJI_NOTIFICATION_DELIVERY_TIMEOUT_SECONDS=5
MAMOJI_SMOKE_EMAIL=admin@example.com
MAMOJI_SMOKE_PASSWORD=replace-with-the-current-admin-password

MAMOJI_OBJECT_STORAGE_ENABLED=true
MAMOJI_MINIO_ACCESS_KEY=replace-with-a-random-access-key
MAMOJI_MINIO_SECRET_KEY=replace-with-a-long-random-secret-key
MAMOJI_MINIO_BUCKET=mamoji
MAMOJI_MINIO_EXTERNAL_URL=https://mamoji.example.com
MAMOJI_MINIO_PRESIGNED_URL_EXPIRY_SECONDS=600

MAMOJI_BACKUP_RETENTION_DAYS=14
MAMOJI_PROMETHEUS_PORT=127.0.0.1:39090
